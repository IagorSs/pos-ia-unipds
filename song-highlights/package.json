{
  "name": "song-recommender-memory",
  "version": "1.0.0",
  "description": "Song recommender with LangGraph memory persistence using LibSQL",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "chat:erickwendel": "node --experimental-strip-types --env-file .env src/index.ts --user erickwendel",
    "chat:ana": "node --experimental-strip-types --env-file .env src/index.ts --user ana",
    "test": "node --experimental-strip-types --env-file .env --test tests/**/*.test.ts",
    "test:watch": "node --experimental-strip-types --env-file .env --test --watch tests/**/*.test.ts",
    "langgraph:serve": "npx @langchain/langgraph-cli dev --host 0.0.0.0 --no-browser"
  },
  "keywords": [
    "langchain",
    "langgraph",
    "memory",
    "libsql",
    "sqlite",
    "song-recommender",
    "openrouter"
  ],
  "author": "erickwendel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.3.0",
    "@langchain/langgraph-cli": "^1.4.2"
  },
  "engines": {
    "node": ">=24.10.0"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.12",
    "@huggingface/transformers": "^3.8.1",
    "@langchain/community": "^1.1.14",
    "@langchain/core": "^1.1.22",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.0",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@libsql/client": "^0.17.0",
    "@openrouter/sdk": "^0.8.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.10.0",
    "knex": "^3.1.0",
    "langchain": "^1.2.21"
  },
  "allowScripts": {
    "@openrouter/sdk@0.8.0": true,
    "sharp@0.32.6": true,
    "sharp@0.34.5": true,
    "protobufjs@6.11.6": true,
    "protobufjs@7.6.5": true,
    "onnxruntime-node@1.21.0": true,
    "better-sqlite3@11.10.0": true,
    "better-sqlite3@12.11.1": true
  }
}
